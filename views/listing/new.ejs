<% layout("Layout/boilerplate") %>
<body>

  <div class="row mt-3">
    <div class="col-8 offset-2">
    <h3> Add New Listing</h3>

<form action="/listings/new/save" method="post" class="needs-validation" novalidate enctype="multipart/form-data">
  <div class="md-3">
    <label for="title" class="form-label">Title</label>
    <input type="text" class="form-control" id="title" name="listing[title]" required >
    <div class="invalid-feedback">
        Please enter a title.
      </div>
  </div>
  <br>
  <div class="md-3">
    <label for="description" class="form-label" >Discription</label>
    <textarea type="text" class="form-control" id="discription" name="listing[description]" required ></textarea>
    <div class="invalid-feedback">
        Please enter Description.
      </div>
  </div>
  <br>
  <div class="md-3">
    <label for="location" class="form-label">Address</label>
    <input type="text" class="form-control"  name="listing[location]" id="location" placeholder="1234 Main St" required >
    <div class="invalid-feedback">
        Please enter a location.
      </div>
  </div>
  <br>
  <div class="row ">
  <div class="md-3 col-6">
    <label for="price" class="form-label" >price</label>
    <input type="number" class="form-control" id="price" placeholder="Enter price for one night" name="listing[price]" required >
    <div class="invalid-feedback">
        Please enter a valid price.
      </div>
  </div>
  <div class="md-3 col-6">
    <label for="country" class="form-label">country</label>
    <input type="text" class="form-control" id="country" placeholder="country" name="listing[country]" required>
    <div class="invalid-feedback">
        Please enter Country.
      </div>
  </div>
  </div>
  <br>
  <div class="md-3">
    <label for="image" class="form-label">Upload Image</label>
    <input type="file" class="form-control" id="image" name="listing[image]" required>
  </div>
  <br> 
    <button type="submit" class="btn">Add</button>
  
</form>

</div>
  </div>
</body>
</html>