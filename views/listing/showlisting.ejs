<% layout("Layout/boilerplate") %>
<script>
  mapToken = "<%= process.env.MAP_TOKEN %>";
  coordinates = <%- JSON.stringify(listing.geometry.coordinates) %>;

</script>
<div class="row mt-3" style="padding-bottom: 5rem;">
    
    <div class="col-12 col-md-8 offset-md-2">

<div class="card listing-card">
  <img src="<%= listing.image.url %>" class="card-img-top" alt="image" style="height: 20rem;">
  <div class="card-body">
    <i><p>Onwed By  : <%= listing.owner.username %></p></i>
    <p class="card-text"><b><%= listing.title %></b>
    <br>
    <%= listing.description %>
    <br>
    &#8377; <%= listing.price.toLocaleString("en-In") %> / night
    <br>
    <%= listing.location %>
    <br>
    <%= listing.country %>

</p>
  </div>
</div>


<% if(currUser && currUser._id.equals(listing.owner._id)) { %>
<div class="shbtn">
<form method="get" action="/listings/edit/<%= listing._id %>">
<button type="submit" class="bt1" >Edit</button>
</form>
<form  method="post" action="/listings/delete/<%= listing._id %>?_method=DELETE">
    <button type="submit" class="bt2">Delete</button>
</form>
</div>
<% } %>
</div>
<br>
<b><hr></b>
<br>


  <div class="col-12 col-md-8 offset-md-2">
 <% if(currUser) { %>
  <h4>Leave a Review</h4>
<form action="/listings/<%= listing._id %>/review" method="post">
  <label for="rating" id="rating" class="form-label">Rating:</label>
  <fieldset class="starability-slot">
  <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="review[rating]" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="review[rating]" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="review[rating]" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="review[rating]" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="review[rating]" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
  <div>
      <label for="rating" id="comment" class="form-label">Comment:</label>
  <textarea class="form-control" name="review[comment]" cols="10" rows="5"></textarea>
  </div>
  <br>
  
  <button type="submit" class="btdl">Submit</button>
  
</form>
<% } %>

<br>

<br>
<% if(listing.reviews.length > 0) { %>
  <hr>
<h5>All Reviews</h5>
<% } %>
<div class="row">
<% for(review of listing.reviews) { %>
 <div class="card col-12 col-md-5 mb-3">
  
  <div class="card-body">
    <h5 class="card-title">@<%= review.author.username %></h5>
    <p class="card-text"><%= review.comment %></p>
    <p class="starability-result card-text " data-rating="<%= review.rating %>"></p>
    <% if(currUser && currUser._id.equals(review.author._id)) { %>
    <form method="post" action="/listings/<%= listing._id %>/review/<%= review._id %>?_method=DELETE">
      <button class="bt btn-sm btn-dark">Delete</button>
    </form>
    <% } %>
    
  </div>
</div>
 <% } %>
</div>


<!-- map -->
 <h3>Where you'll be</h3>
 <div id="map"></div>

</div>
</div>
<script src="/js/map.js"></script>

